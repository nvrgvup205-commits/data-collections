# Supabase configuration (optional).
# If these are set, the app uses Supabase for auth (and, once wired, data).
# If they are left empty, the app runs in local demo mode with built-in
# demo accounts (e.g. 1111 / 1111).
#
# The anon key is a public client key (safe to expose in the frontend).
# On Cloudflare Workers Builds, add these as Build environment variables.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
