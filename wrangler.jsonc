{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "data-collections",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "build": {
    "command": "npm run build"
  }
}
